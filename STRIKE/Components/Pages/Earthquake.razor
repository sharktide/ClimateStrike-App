@page "/earthquake"
@using STRIKE
@using STRIKE.Inference
@using STRIKE.Services
@inject RegionAutofillService Autofill

<style>
    html, body, .mud-layout, .mud-main-content, .mud-layout-content {
        background-color: #0a0d12 !important;
    }
    .strike-grid-bg {
        position: fixed; inset: 0;
        background-image:
            linear-gradient(rgba(59,124,255,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59,124,255,.04) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none; z-index: 0;
    }
    .page-shell {
        position: relative; z-index: 1;
        max-width: 1100px; margin: 0 auto;
        padding: 28px 20px 64px;
        font-family: 'Inter', sans-serif;
        color: #e8eaf0;
    }
    .page-back {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .75rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
        color: rgba(232,234,240,.4); text-decoration: none;
        margin-bottom: 20px; transition: color .15s;
    }
    .page-back:hover { color: #e8a020; }
    .page-header {
        display: flex; align-items: center; gap: 14px;
        margin-bottom: 28px; padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,.07);
    }
    .page-icon {
        width: 46px; height: 46px; border-radius: 11px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #e8a020, #c86000);
        box-shadow: 0 0 20px rgba(232,160,32,.3);
    }
    .page-icon .mud-icon-root { font-size: 24px; color: #fff; }
    .page-title { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .page-sub   { font-size: .75rem; color: rgba(232,234,240,.45); margin-top: 3px; }
    .predictor-card {
        background: #111520;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 14px; padding: 24px; color: #e8eaf0;
    }
    .param-block { margin-bottom: 20px; }
    .param-label {
        display: flex; align-items: center; gap: 6px;
        font-size: .78rem; font-weight: 600; letter-spacing: .03em;
        color: #e8eaf0; margin-bottom: 2px;
    }
    .param-hint { font-size: .7rem; color: rgba(232,234,240,.45); margin-bottom: 6px; }
    .result-card {
        border-radius: 10px; padding: 18px 20px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.03);
        min-height: 64px; display: flex; align-items: center;
    }
    .result-text { font-size: 1rem; font-weight: 600; line-height: 1.35; }
    .section-sep { border: none; border-top: 1px solid rgba(255,255,255,.07); margin: 20px 0; }
</style>

<div class="strike-grid-bg"></div>
<div class="page-shell">

    <a class="page-back" href="/">
        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:15px;" /> Dashboard
    </a>

    <div class="page-header">
        <div class="page-icon"><MudIcon Icon="@Icons.Material.Filled.Landscape" /></div>
        <div>
            <div class="page-title">Earthquake Predictor</div>
            <div class="page-sub">Seismic risk assessment based on fault and ground motion parameters</div>
        </div>
    </div>

    <div class="predictor-card">
        <MudGrid>
            <MudItem xs="12" sm="6">

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Color="Color.Warning" />
                    <MudText Typo="Typo.caption" Style="color:rgba(232,234,240,.6);">Autofill defaults for your region</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.GpsFixed"
                               Disabled="@_autofilling" OnClick="AutofillFromRegion">
                        @(_autofilling ? "Locating…" : "Autofill")
                    </MudButton>
                </MudStack>
                @if (_autofillError != null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_autofillError</MudAlert>
                }

                <div class="param-block">
                    <div class="param-label">Seismic Moment Rate
                        <MudTooltip Text="Total seismic energy release rate from tremors. Higher = more active fault stress." Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                        </MudTooltip>
                    </div>
                    <div class="param-hint">Range: 0.5 – 25 × 10¹⁶ Nm/s</div>
                    <MudSlider T="float" Min="0.5f" Max="25.0f" Step="0.1f" @bind-Value="_momentRate"
                               Variant="Variant.Filled" Color="Color.Warning" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_momentRate.ToString("0.0")</MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.6;">× 10¹⁶ Nm/s</MudText>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Surface Displacement Rate
                        <MudTooltip Text="How fast the ground surface is shifting. Measured by GPS/InSAR." Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                        </MudTooltip>
                    </div>
                    <div class="param-hint">Range: 0 – 100 mm/yr</div>
                    <MudSlider T="float" Min="0f" Max="100f" Step="1f" @bind-Value="_displacementRate"
                               Variant="Variant.Filled" Color="Color.Warning" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_displacementRate.ToString()</MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.6;">mm/yr</MudText>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Coulomb Stress Change
                        <MudTooltip Text="Fault stress changes from prior seismic events. Positive values can trigger nearby quakes." Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                        </MudTooltip>
                    </div>
                    <div class="param-hint">Range: 0 – 700 Pa</div>
                    <MudSlider T="float" Min="0f" Max="700f" Step="1f" @bind-Value="_stressChange"
                               Variant="Variant.Filled" Color="Color.Warning" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_stressChange.ToString()</MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.6;">Pa</MudText>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Average Focal Depth
                        <MudTooltip Text="Typical depth where earthquakes originate. Shallow quakes (< 20 km) cause more surface damage." Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                        </MudTooltip>
                    </div>
                    <div class="param-hint">Range: 0 – 60 km</div>
                    <MudSlider T="float" Min="0f" Max="60f" Step="1f" @bind-Value="_focalDepth"
                               Variant="Variant.Filled" Color="Color.Warning" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_focalDepth.ToString()</MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.6;">km depth</MudText>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Fault Slip Rate
                        <MudTooltip Text="Long-term rate of fault movement due to tectonic loading. Higher = more accumulated strain." Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                        </MudTooltip>
                    </div>
                    <div class="param-hint">Range: 0 – 20 mm/yr</div>
                    <MudSlider T="float" Min="0f" Max="20f" Step="0.1f" @bind-Value="_slipRate"
                               Variant="Variant.Filled" Color="Color.Warning" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_slipRate.ToString("0.0")</MudChip>
                        <MudText Typo="Typo.caption" Style="opacity:.6;">mm/yr</MudText>
                    </MudStack>
                </div>

                <hr class="section-sep" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                    <MudTooltip Text="Uses the EarthquakeTrustNet ensemble for higher-confidence results." Arrow="true">
                        <MudCheckBox @bind-Value="_useTrust" T="bool" Label="EarthquakeTrustNet" Color="Color.Primary" />
                    </MudTooltip>
                    <MudTooltip Text="Fetches supplementary online data during inference. Disabled on Apple platforms." Arrow="true">
                        <MudCheckBox @bind-Value="_useInternet" T="bool" Label="Use Internet"
                                     Disabled="@_isApplePlatform" Color="Color.Secondary" />
                    </MudTooltip>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                           Size="Size.Large" StartIcon="@Icons.Material.Filled.Analytics"
                           Disabled="@_isPredicting" OnClick="RunPrediction">
                    @(_isPredicting ? "Analysing…" : "Run Prediction")
                </MudButton>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.overline" Style="opacity:.5;letter-spacing:.1em;">Earthquake Risk Verdict</MudText>
                <div class="result-card mt-1 mb-4">
                    @if (_isPredicting)
                    {
                        <MudProgressCircular Indeterminate="true" Color="Color.Warning" Size="Size.Small" Class="mr-3" />
                        <MudText Class="result-text" Style="opacity:.6;">Running model…</MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(_predictionResult))
                    {
                        <MudText Class="result-text">@_predictionResult</MudText>
                    }
                    else
                    {
                        <MudText Style="opacity:.3;font-size:.85rem;">Adjust the parameters and press Run Prediction.</MudText>
                    }
                </div>
                @if (_showAlert)
                {
                    <MudAlert Severity="@_alertSeverity" Dense="true" Class="mb-3">@_alertMessage</MudAlert>
                }
                <MudExpansionPanels Elevation="0">
                    <MudExpansionPanel Style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="opacity:.6;" />
                                <MudText Typo="Typo.body2">Parameter Reference</MudText>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Seismic Moment Rate (×10¹⁶ Nm/s)</strong> — Total energy release rate from seismic events.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Surface Displacement Rate (mm/yr)</strong> — Horizontal/vertical ground motion observed via GPS/InSAR.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Coulomb Stress Change (Pa)</strong> — Fault stress changes post-seismic activity.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Average Focal Depth (km)</strong> — Typical depth of earthquakes in the region.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block"><strong>Fault Slip Rate (mm/yr)</strong> — Long-term fault motion due to tectonic loading.</MudText>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
        </MudGrid>
    </div>
</div>

@code {
    private bool _isPredicting, _autofilling;
    private string? _autofillError;
    private string _alertMessage = ""; private Severity _alertSeverity = Severity.Normal; private bool _showAlert;
    private bool _useInternet = true;
    private bool _isApplePlatform = OperatingSystem.IsIOS() || OperatingSystem.IsMacOS();
    private float _momentRate = 15.0f, _displacementRate = 35f, _stressChange = 300f, _focalDepth = 18f, _slipRate = 7.0f;
    private bool _useTrust = true;
    private string _predictionResult = "";

    protected override void OnInitialized() { if (_isApplePlatform) _useInternet = true; }

    private async Task AutofillFromRegion()
    {
        _autofilling = true; _autofillError = null; StateHasChanged();
        try
        {
            var d = await Autofill.GetEarthquakeDefaultsAsync();
            if (d == null) { _autofillError = "Location unavailable. Please allow location access and try again."; return; }
            _momentRate = d.MomentRate; _displacementRate = d.DisplacementRate;
            _stressChange = d.StressChange; _focalDepth = d.FocalDepth; _slipRate = d.SlipRate;
        }
        catch (Exception ex) { _autofillError = $"Autofill failed: {ex.Message}"; }
        finally { _autofilling = false; StateHasChanged(); }
    }

    private async Task RunPrediction()
    {
        _isPredicting = true; _showAlert = false; _predictionResult = ""; StateHasChanged();
        try
        {
            _predictionResult = await Task.Run(() => EarthquakeModelRunner.Predict(
                new[] { _momentRate, _displacementRate, _stressChange, _focalDepth, _slipRate }, _useTrust, _useInternet));
            _alertMessage = "Prediction successful."; _alertSeverity = Severity.Success; _showAlert = true;
        }
        catch (Exception ex) { _predictionResult = ""; _alertMessage = $"Prediction failed: {ex.Message}"; _alertSeverity = Severity.Error; _showAlert = true; }
        finally { _isPredicting = false; StateHasChanged(); }
    }
}
