@page "/wildfire"
@using STRIKE
@using STRIKE.Inference
@using STRIKE.Services
@inject RegionAutofillService Autofill

<style>
    html, body, .mud-layout, .mud-main-content, .mud-layout-content { background-color: #0a0d12 !important; }
    .strike-grid-bg { position:fixed;inset:0;background-image:linear-gradient(rgba(59,124,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(59,124,255,.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0; }
    .page-shell { position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:28px 20px 64px;font-family:'Inter',sans-serif;color:#e8eaf0; }
    .page-back { display:inline-flex;align-items:center;gap:6px;font-size:.75rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(232,234,240,.4);text-decoration:none;margin-bottom:20px;transition:color .15s; }
    .page-back:hover { color:#ff4500; }
    .page-header { display:flex;align-items:center;gap:14px;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,.07); }
    .page-icon { width:46px;height:46px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#ff6b35,#c0392b);box-shadow:0 0 20px rgba(255,107,53,.3); }
    .page-icon .mud-icon-root { font-size:24px;color:#fff; }
    .page-title { font-size:1.5rem;font-weight:700;line-height:1; }
    .page-sub { font-size:.75rem;color:rgba(232,234,240,.45);margin-top:3px; }
    .predictor-card { background:#111520;border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:24px;color:#e8eaf0; }
    .param-block { margin-bottom:20px; }
    .param-label { display:flex;align-items:center;gap:6px;font-size:.78rem;font-weight:600;letter-spacing:.03em;color:#e8eaf0;margin-bottom:2px; }
    .param-hint { font-size:.7rem;color:rgba(232,234,240,.45);margin-bottom:6px; }
    .result-card { border-radius:10px;padding:18px 20px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);min-height:64px;display:flex;align-items:center; }
    .result-text { font-size:1rem;font-weight:600;line-height:1.35; }
    .section-sep { border:none;border-top:1px solid rgba(255,255,255,.07);margin:20px 0; }
</style>

<div class="strike-grid-bg"></div>
<div class="page-shell">
    <a class="page-back" href="/"><MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:15px;" /> Dashboard</a>
    <div class="page-header">
        <div class="page-icon"><MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" /></div>
        <div>
            <div class="page-title">Wildfire Predictor</div>
            <div class="page-sub">Fire ignition and spread risk based on weather and vegetation parameters</div>
        </div>
    </div>
    <div class="predictor-card">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Color="Color.Error" />
                    <MudText Typo="Typo.caption" Style="color:rgba(232,234,240,.6);">Autofill defaults for your region</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error" StartIcon="@Icons.Material.Filled.GpsFixed" Disabled="@_autofilling" OnClick="AutofillFromRegion">@(_autofilling ? "Locating…" : "Autofill")</MudButton>
                </MudStack>
                @if (_autofillError != null) { <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_autofillError</MudAlert> }

                <div class="param-block">
                    <div class="param-label">Temperature <MudTooltip Text="Current air temperature in the target area. Higher temperatures dry out vegetation and lower ignition thresholds." Arrow="true"><MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" /></MudTooltip></div>
                    <div class="param-hint">Range: @TemperatureMin.ToString("0") – @TemperatureMax.ToString("0") @(_temperatureUnit == "K" ? "K" : _temperatureUnit == "F" ? "°F" : "°C")</div>
                    <MudSlider T="float" Min="@TemperatureMin" Max="@TemperatureMax" Step="1f" @bind-Value="_temperature" Variant="Variant.Filled" Color="Color.Error" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_temperature.ToString()</MudChip>
                        <MudSelect T="string" Dense="true" @bind-Value="_temperatureUnit" Style="width:80px;"><MudSelectItem Value="@("K")">Kelvin</MudSelectItem><MudSelectItem Value="@("C")">°C</MudSelectItem><MudSelectItem Value="@("F")">°F</MudSelectItem></MudSelect>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Humidity <MudTooltip Text="Relative humidity. Below 20% the risk of ignition and rapid fire spread increases sharply." Arrow="true"><MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" /></MudTooltip></div>
                    <div class="param-hint">Range: 0 – 100 %</div>
                    <MudSlider T="float" Min="0f" Max="100f" Step="1f" @bind-Value="_humidity" Variant="Variant.Filled" Color="Color.Error" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1"><MudChip T="string" Size="Size.Small" Color="Color.Dark">@_humidity.ToString()</MudChip><MudText Typo="Typo.caption" Style="opacity:.6;">%</MudText></MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Wind Speed <MudTooltip Text="Average wind speed in the target area. Wind drives fire spread and carries embers ahead of the fire front." Arrow="true"><MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" /></MudTooltip></div>
                    <div class="param-hint">Range: 0 – @WindSpeedMax.ToString("0") @_windSpeedUnit</div>
                    <MudSlider T="float" Min="0f" Max="@WindSpeedMax" Step="1f" @bind-Value="_windSpeed" Variant="Variant.Filled" Color="Color.Error" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_windSpeed.ToString()</MudChip>
                        <MudSelect T="string" Dense="true" @bind-Value="_windSpeedUnit" Style="width:80px;"><MudSelectItem Value="@("m/s")">m/s</MudSelectItem><MudSelectItem Value="@("km/h")">kph</MudSelectItem><MudSelectItem Value="@("mp/h")">mph</MudSelectItem></MudSelect>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Elevation <MudTooltip Text="Height above sea level. Higher elevations often have drier conditions and stronger winds, increasing fire risk." Arrow="true"><MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" /></MudTooltip></div>
                    <div class="param-hint">Range: 0 – @ElevationMax.ToString("0") @_elevationUnit</div>
                    <MudSlider T="float" Min="0f" Max="@ElevationMax" Step="10f" @bind-Value="_elevation" Variant="Variant.Filled" Color="Color.Error" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_elevation.ToString()</MudChip>
                        <MudSelect T="string" Dense="true" @bind-Value="_elevationUnit" Style="width:72px;"><MudSelectItem Value="@("m")">m</MudSelectItem><MudSelectItem Value="@("ft")">ft</MudSelectItem></MudSelect>
                    </MudStack>
                </div>

                <div class="param-block">
                    <div class="param-label">Vegetation Index <MudTooltip Text="NDVI score: -1 (bare/water) to +1 (dense green). Dry stressed vegetation (low positive values) is the most flammable." Arrow="true"><MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" /></MudTooltip></div>
                    <div class="param-hint">Range: -1.0 – 1.0 NDVI</div>
                    <MudSlider T="float" Min="-1.0f" Max="1.0f" Step="0.01f" @bind-Value="_vegetationIndex" Variant="Variant.Filled" Color="Color.Error" ValueLabel="true" />
                    <MudStack Row="true" Spacing="1"><MudChip T="string" Size="Size.Small" Color="Color.Dark">@_vegetationIndex.ToString("0.00")</MudChip><MudText Typo="Typo.caption" Style="opacity:.6;">NDVI</MudText></MudStack>
                </div>

                <hr class="section-sep" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                    <MudTooltip Text="Uses the FireTrustNet ensemble for higher-confidence results." Arrow="true"><MudCheckBox @bind-Value="_useTrust" T="bool" Label="FireTrustNet" Color="Color.Primary" /></MudTooltip>
                    <MudTooltip Text="Fetches supplementary online data during inference. Disabled on Apple platforms." Arrow="true"><MudCheckBox @bind-Value="_useInternet" T="bool" Label="Use Internet" Disabled="@_isApplePlatform" Color="Color.Secondary" /></MudTooltip>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" Size="Size.Large" StartIcon="@Icons.Material.Filled.Analytics" Disabled="@_isPredicting" OnClick="RunPrediction">@(_isPredicting ? "Analysing…" : "Run Prediction")</MudButton>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.overline" Style="opacity:.5;letter-spacing:.1em;">Wildfire Risk Verdict</MudText>
                <div class="result-card mt-1 mb-4">
                    @if (_isPredicting) { <MudProgressCircular Indeterminate="true" Color="Color.Error" Size="Size.Small" Class="mr-3" /><MudText Class="result-text" Style="opacity:.6;">Running model…</MudText> }
                    else if (!string.IsNullOrWhiteSpace(_predictionResult)) { <MudText Class="result-text">@_predictionResult</MudText> }
                    else { <MudText Style="opacity:.3;font-size:.85rem;">Adjust the parameters and press Run Prediction.</MudText> }
                </div>
                @if (_showAlert) { <MudAlert Severity="@_alertSeverity" Dense="true" Class="mb-3">@_alertMessage</MudAlert> }
                <MudExpansionPanels Elevation="0">
                    <MudExpansionPanel Style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;">
                        <TitleContent><MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"><MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="opacity:.6;" /><MudText Typo="Typo.body2">Parameter Reference</MudText></MudStack></TitleContent>
                        <ChildContent>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Temperature</strong> — Current air temperature in the target area.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Humidity (%)</strong> — Relative humidity of the air.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Wind Speed</strong> — Average wind speed in the target area.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Elevation</strong> — Height above sea level.</MudText>
                            <MudText Typo="Typo.caption" Class="d-block"><strong>Vegetation Index (NDVI)</strong> — Greenness of vegetation; lower values = drier fuel load.</MudText>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
        </MudGrid>
    </div>
</div>

@code {
    private bool _isPredicting, _autofilling; private string? _autofillError;
    private string _alertMessage = ""; private Severity _alertSeverity = Severity.Normal; private bool _showAlert;
    private bool _useInternet = true; private bool _isApplePlatform = OperatingSystem.IsIOS() || OperatingSystem.IsMacOS();
    private float _temperature = 310f, _humidity = 10f, _windSpeed = 6f, _elevation = 1500f, _vegetationIndex = 0.8f;
    private string _temperatureUnit = "K", _windSpeedUnit = "m/s", _elevationUnit = "m";
    private bool _useTrust = true; private string _predictionResult = "";
    private float TemperatureMin => _temperatureUnit switch { "C" => -50f, "F" => -58f, _ => 223f };
    private float TemperatureMax => _temperatureUnit switch { "C" => 60f, "F" => 140f, _ => 333f };
    private float WindSpeedMax => _windSpeedUnit switch { "km/h" => 180f, "mp/h" => 110f, _ => 50f };
    private float ElevationMax => _elevationUnit == "ft" ? 10000f : 3000f;
    protected override void OnInitialized() { if (_isApplePlatform) _useInternet = true; }
    private async Task AutofillFromRegion()
    {
        _autofilling = true; _autofillError = null; StateHasChanged();
        try { var d = await Autofill.GetWildfireDefaultsAsync(); if (d == null) { _autofillError = "Location unavailable. Please allow location access and try again."; return; } _temperature = d.TemperatureK; _temperatureUnit = "K"; _humidity = d.Humidity; _windSpeed = d.WindSpeedMs; _windSpeedUnit = "m/s"; _elevation = d.Elevation; _elevationUnit = "m"; _vegetationIndex = d.VegetationIndex; }
        catch (Exception ex) { _autofillError = $"Autofill failed: {ex.Message}"; }
        finally { _autofilling = false; StateHasChanged(); }
    }
    private async Task RunPrediction()
    {
        _isPredicting = true; _showAlert = false; _predictionResult = ""; StateHasChanged();
        try
        {
            var tK = _temperatureUnit switch { "C" => _temperature + 273.15f, "F" => (_temperature - 32f) * 5f / 9f + 273.15f, _ => _temperature };
            var wMs = _windSpeedUnit switch { "km/h" => _windSpeed / 3.6f, "mp/h" => _windSpeed * 0.44704f, _ => _windSpeed };
            var elM = _elevationUnit == "ft" ? _elevation * 0.3048f : _elevation;
            _predictionResult = await Task.Run(() => WildfireModelRunner.Predict(new[] { tK, _humidity, wMs, _vegetationIndex + 1f, elM }, _useTrust, _useInternet));
            _alertMessage = "Prediction successful."; _alertSeverity = Severity.Success; _showAlert = true;
        }
        catch (Exception ex) { _predictionResult = ""; _alertMessage = $"Prediction failed: {ex.Message}"; _alertSeverity = Severity.Error; _showAlert = true; }
        finally { _isPredicting = false; StateHasChanged(); }
    }
}
