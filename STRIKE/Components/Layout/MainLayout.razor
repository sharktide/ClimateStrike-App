@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider  @ref="_mudThemeProvider" Theme="@StrikeTheme" IsDarkMode="_isDarkMode" />
<MudSnackbarProvider />
<MudDialogProvider />
<MudPopoverProvider />

<MudLayout>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private MudTheme _theme = new();
    private MudThemeProvider ?_mudThemeProvider;


    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private MudTheme StrikeTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#80CBC4",
            Background = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#212121",
            TextSecondary = "#757575",
            Surface = "#F8F9FA",
            ActionDefault = "#B0BEC5",
            ActionDisabled = "#CFD8DC",
            Divider = "#E0E0E0"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#528AAE"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider!.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }
    private Task OnSystemDarkModeChanged(bool newValue)
    {
        _isDarkMode = newValue;
        StateHasChanged();
        return Task.CompletedTask;
    }
    private void OnDrawerOpenChanged(bool isOpen)
    {
        _drawerOpen = isOpen;
        StateHasChanged();
    }
}
