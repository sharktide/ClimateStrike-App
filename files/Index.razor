@page "/"
@inject STRIKE.Services.IDashboardDataService DashboardDataService

<style>
    /* ── STRIKE Dashboard – Command Centre Theme ── */
    @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap');

    .strike-dash {
        --clr-bg:        #0a0d12;
        --clr-surface:   #111520;
        --clr-border:    rgba(255,255,255,0.07);
        --clr-accent:    #e8a020;
        --clr-accent2:   #3b7cff;
        --clr-danger:    #ff4646;
        --clr-ok:        #27c97e;
        --clr-text:      #e8eaf0;
        --clr-muted:     rgba(232,234,240,0.45);
        font-family: 'Inter', sans-serif;
        background: var(--clr-bg);
        min-height: 100vh;
        color: var(--clr-text);
        padding: 0;
    }

    /* grid-line background */
    .strike-dash::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
            linear-gradient(rgba(59,124,255,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59,124,255,.04) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
    }

    .dash-inner { position: relative; z-index: 1; padding: 28px 24px 48px; max-width: 1280px; margin: 0 auto; }

    /* ── Hero header ── */
    .hero-band {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--clr-border);
    }
    .hero-icon {
        width: 54px; height: 54px;
        background: linear-gradient(135deg, var(--clr-accent) 0%, #c86000 100%);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 24px rgba(232,160,32,.35);
        flex-shrink: 0;
    }
    .hero-icon .mud-icon-root { font-size: 28px; color: #fff; }
    .hero-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: .04em;
        line-height: 1;
        color: var(--clr-text);
    }
    .hero-sub { font-size: .8rem; color: var(--clr-muted); margin-top: 3px; letter-spacing: .06em; text-transform: uppercase; }

    .live-pill {
        margin-left: auto;
        display: flex; align-items: center; gap: 7px;
        background: rgba(39,201,126,.1);
        border: 1px solid rgba(39,201,126,.25);
        border-radius: 99px;
        padding: 5px 14px;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--clr-ok);
        white-space: nowrap;
    }
    .live-dot {
        width: 7px; height: 7px;
        background: var(--clr-ok);
        border-radius: 50%;
        animation: pulse-dot 1.6s ease-in-out infinite;
    }
    @keyframes pulse-dot {
        0%,100% { opacity:1; transform:scale(1); }
        50%      { opacity:.4; transform:scale(.7); }
    }

    /* ── Card base ── */
    .s-card {
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: 14px;
        padding: 22px;
        height: 100%;
        box-sizing: border-box;
        position: relative;
        overflow: hidden;
    }
    .s-card::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 14px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
        pointer-events: none;
    }
    .card-label {
        font-family: 'Rajdhani', sans-serif;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--clr-muted);
        margin-bottom: 16px;
        display: flex; align-items: center; gap: 8px;
    }
    .card-label-line {
        flex: 1;
        height: 1px;
        background: var(--clr-border);
    }

    /* ── Quick-access disaster buttons ── */
    .disaster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 10px;
        margin-top: 4px;
    }
    .d-btn {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 8px;
        background: rgba(255,255,255,.03);
        border: 1px solid var(--clr-border);
        border-radius: 10px;
        padding: 14px 8px;
        cursor: pointer;
        transition: background .18s, border-color .18s, transform .15s;
        text-decoration: none;
        color: var(--clr-text);
    }
    .d-btn:hover {
        background: rgba(232,160,32,.08);
        border-color: rgba(232,160,32,.35);
        transform: translateY(-2px);
    }
    .d-btn .mud-icon-root { font-size: 26px; }
    .d-btn span { font-size: .72rem; font-weight: 500; text-align: center; line-height: 1.2; }

    /* ── Model accuracy bars ── */
    .acc-row { margin-bottom: 14px; }
    .acc-header { display: flex; justify-content: space-between; margin-bottom: 5px; }
    .acc-name { font-size: .8rem; font-weight: 500; }
    .acc-pct  { font-size: .8rem; font-weight: 700; color: var(--clr-accent); font-family: 'Rajdhani', sans-serif; }
    .acc-track {
        height: 5px; background: rgba(255,255,255,.07);
        border-radius: 99px; overflow: hidden;
    }
    .acc-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, var(--clr-accent2) 0%, var(--clr-accent) 100%);
        transition: width .6s cubic-bezier(.4,0,.2,1);
    }

    /* ── Recent predictions ── */
    .pred-row {
        display: flex; align-items: center; gap: 12px;
        padding: 11px 0;
        border-bottom: 1px solid var(--clr-border);
    }
    .pred-row:last-child { border-bottom: none; }
    .pred-icon-wrap {
        width: 36px; height: 36px; border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        background: rgba(59,124,255,.12);
        border: 1px solid rgba(59,124,255,.2);
    }
    .pred-icon-wrap .mud-icon-root { font-size: 18px; color: var(--clr-accent2); }
    .pred-type  { font-size: .82rem; font-weight: 600; }
    .pred-label { font-size: .72rem; color: var(--clr-muted); margin-top: 1px; }
    .pred-time  { margin-left: auto; font-size: .7rem; color: var(--clr-muted); white-space: nowrap; font-family: 'Rajdhani', sans-serif; letter-spacing: .03em; }

    .risk-chip {
        display: inline-block;
        border-radius: 5px;
        padding: 2px 9px;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
    }
    .risk-low    { background: rgba(39,201,126,.15); color: var(--clr-ok); border: 1px solid rgba(39,201,126,.3); }
    .risk-medium { background: rgba(232,160,32,.15); color: var(--clr-accent); border: 1px solid rgba(232,160,32,.3); }
    .risk-high   { background: rgba(255,70,70,.15); color: var(--clr-danger); border: 1px solid rgba(255,70,70,.3); }

    .view-history-btn {
        display: block; text-align: center;
        margin-top: 14px;
        padding: 9px;
        border: 1px dashed rgba(255,255,255,.12);
        border-radius: 8px;
        font-size: .75rem;
        color: var(--clr-muted);
        text-decoration: none;
        transition: background .15s, color .15s;
        letter-spacing: .04em;
    }
    .view-history-btn:hover { background: rgba(255,255,255,.04); color: var(--clr-text); }

    /* ── Stat pills at top ── */
    .stat-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 26px; }
    .stat-pill {
        flex: 1; min-width: 120px;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: 12px;
        padding: 16px 18px;
        display: flex; flex-direction: column; gap: 4px;
    }
    .stat-val { font-family: 'Rajdhani', sans-serif; font-size: 1.6rem; font-weight: 700; line-height: 1; }
    .stat-desc { font-size: .7rem; color: var(--clr-muted); letter-spacing: .04em; text-transform: uppercase; }
    .stat-pill.accent  { border-color: rgba(232,160,32,.3); }
    .stat-pill.accent  .stat-val { color: var(--clr-accent); }
    .stat-pill.accent2 { border-color: rgba(59,124,255,.3); }
    .stat-pill.accent2 .stat-val { color: var(--clr-accent2); }
    .stat-pill.ok      { border-color: rgba(39,201,126,.3); }
    .stat-pill.ok      .stat-val { color: var(--clr-ok); }

    /* ── No-results empty state ── */
    .empty-state {
        text-align: center; padding: 32px 16px;
        color: var(--clr-muted); font-size: .82rem;
    }
    .empty-state .mud-icon-root { font-size: 38px; opacity: .25; display: block; margin: 0 auto 10px; }

    /* skeleton shimmer */
    .shimmer {
        background: linear-gradient(90deg, rgba(255,255,255,.04) 25%, rgba(255,255,255,.08) 50%, rgba(255,255,255,.04) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px; height: 14px; margin-bottom: 10px;
    }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

<div class="strike-dash">
    <div class="dash-inner">

        @* ── Hero band ── *@
        <div class="hero-band">
            <div class="hero-icon">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" />
            </div>
            <div>
                <div class="hero-title">STRIKE</div>
                <div class="hero-sub">Natural Disaster Intelligence Platform</div>
            </div>
            <div class="live-pill">
                <div class="live-dot"></div>
                Models Online
            </div>
        </div>

        @* ── Stat pills ── *@
        <div class="stat-row">
            <div class="stat-pill accent">
                <div class="stat-val">8</div>
                <div class="stat-desc">Active Models</div>
            </div>
            <div class="stat-pill accent2">
                <div class="stat-val">@(_totalPredictions?.ToString() ?? "—")</div>
                <div class="stat-desc">Total Predictions</div>
            </div>
            <div class="stat-pill ok">
                <div class="stat-val">@(_avgAccuracy != null ? $"{_avgAccuracy:0}%" : "—")</div>
                <div class="stat-desc">Avg. Model Accuracy</div>
            </div>
        </div>

        <MudGrid Spacing="3">

            @* ── LEFT column ── *@
            <MudItem xs="12" md="7">

                @* Quick access *@
                <div class="s-card mb-3">
                    <div class="card-label">
                        <MudIcon Icon="@Icons.Material.Filled.GridView" Style="font-size:14px;" />
                        Run a Predictor
                        <div class="card-label-line"></div>
                    </div>
                    <div class="disaster-grid">
                        <a class="d-btn" href="/earthquake">
                            <MudIcon Icon="@Icons.Material.Filled.Landscape" Style="color:#e8a020;" />
                            <span>Earthquake</span>
                        </a>
                        <a class="d-btn" href="/hurricane">
                            <MudIcon Icon="@Icons.Material.Filled.Cyclone" Style="color:#3b7cff;" />
                            <span>Hurricane</span>
                        </a>
                        <a class="d-btn" href="/tornado">
                            <MudIcon Icon="@Icons.Material.Filled.Air" Style="color:#9b59b6;" />
                            <span>Tornado</span>
                        </a>
                        <a class="d-btn" href="/wildfire">
                            <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Style="color:#ff6b35;" />
                            <span>Wildfire</span>
                        </a>
                        <a class="d-btn" href="/flashflood">
                            <MudIcon Icon="@Icons.Material.Filled.Flood" Style="color:#27c97e;" />
                            <span>Flash Flood</span>
                        </a>
                        <a class="d-btn" href="/fluvialflood">
                            <MudIcon Icon="@Icons.Material.Filled.Water" Style="color:#1abc9c;" />
                            <span>Fluvial Flood</span>
                        </a>
                        <a class="d-btn" href="/pluvialflood">
                            <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Style="color:#5dade2;" />
                            <span>Pluvial Flood</span>
                        </a>
                        <a class="d-btn" href="/predictor">
                            <MudIcon Icon="@Icons.Material.Filled.Apps" Style="color:rgba(232,234,240,.4);" />
                            <span>All Predictors</span>
                        </a>
                    </div>
                </div>

                @* Model accuracy *@
                <div class="s-card">
                    <div class="card-label">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="font-size:14px;" />
                        Model Accuracy
                        <div class="card-label-line"></div>
                    </div>

                    @if (ModelConfidences == null)
                    {
                        <div class="shimmer" style="width:70%;"></div>
                        <div class="shimmer" style="width:90%;"></div>
                        <div class="shimmer" style="width:60%;"></div>
                        <div class="shimmer" style="width:85%;"></div>
                    }
                    else
                    {
                        @foreach (var kvp in ModelConfidences)
                        {
                            var pct = kvp.Value * 100;
                            <div class="acc-row">
                                <div class="acc-header">
                                    <span class="acc-name">@kvp.Key</span>
                                    <span class="acc-pct">@pct.ToString("0.0")%</span>
                                </div>
                                <div class="acc-track">
                                    <div class="acc-fill" style="width:@(pct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </MudItem>

            @* ── RIGHT column ── *@
            <MudItem xs="12" md="5">
                <div class="s-card" style="height:100%;">
                    <div class="card-label">
                        <MudIcon Icon="@Icons.Material.Filled.History" Style="font-size:14px;" />
                        Recent Predictions
                        <div class="card-label-line"></div>
                    </div>

                    @if (RecentPredictionsTruncated == null)
                    {
                        <div class="shimmer"></div>
                        <div class="shimmer" style="width:80%;"></div>
                        <div class="shimmer"></div>
                        <div class="shimmer" style="width:65%;"></div>
                    }
                    else if (!RecentPredictions!.Any())
                    {
                        <div class="empty-state">
                            <MudIcon Icon="@Icons.Material.Filled.QueryStats" />
                            No predictions yet.<br />Run a model to see results here.
                        </div>
                    }
                    else
                    {
                        @foreach (var pred in RecentPredictionsTruncated)
                        {
                            var riskClass = GetRiskClass(pred.Label);
                            <div class="pred-row">
                                <div class="pred-icon-wrap">
                                    <MudIcon Icon="@GetDisasterIcon(pred.DisasterType)" />
                                </div>
                                <div>
                                    <div class="pred-type">@pred.DisasterType</div>
                                    <div class="pred-label">
                                        <span class="risk-chip @riskClass">@pred.Label</span>
                                    </div>
                                </div>
                                <div class="pred-time">@pred.Timestamp.ToString("dd MMM HH:mm")</div>
                            </div>
                        }

                        <a class="view-history-btn" href="/history">
                            View Full History →
                        </a>
                    }
                </div>
            </MudItem>

        </MudGrid>
    </div>
</div>

@code {
    private Dictionary<string, float>? ModelConfidences;
    private List<STRIKE.Services.PredictionResult>? RecentPredictions;
    private List<STRIKE.Services.PredictionResult>? RecentPredictionsTruncated;
    private int? _totalPredictions;
    private double? _avgAccuracy;

    protected override async Task OnInitializedAsync()
    {
        ModelConfidences = await DashboardDataService.GetModelConfidencesAsync();
        RecentPredictions = await DashboardDataService.GetRecentPredictionsAsync();
        RecentPredictionsTruncated = RecentPredictions?.Take(5).ToList();
        _totalPredictions = RecentPredictions?.Count;

        if (ModelConfidences is { Count: > 0 })
            _avgAccuracy = ModelConfidences.Values.Average() * 100;
    }

    private string GetRiskClass(string label)
    {
        var l = label?.ToLowerInvariant() ?? "";
        if (l.Contains("high") || l.Contains("severe") || l.Contains("extreme")) return "risk-high";
        if (l.Contains("medium") || l.Contains("moderate") || l.Contains("elevated")) return "risk-medium";
        return "risk-low";
    }

    private string GetDisasterIcon(string disasterType) =>
        disasterType?.ToLowerInvariant() switch
        {
            var s when s.Contains("earthquake") => Icons.Material.Filled.Landscape,
            var s when s.Contains("hurricane")  => Icons.Material.Filled.Cyclone,
            var s when s.Contains("tornado")    => Icons.Material.Filled.Air,
            var s when s.Contains("wildfire")   => Icons.Material.Filled.LocalFireDepartment,
            var s when s.Contains("flash")      => Icons.Material.Filled.Flood,
            var s when s.Contains("fluvial")    => Icons.Material.Filled.Water,
            var s when s.Contains("pluvial")    => Icons.Material.Filled.WaterDrop,
            _                                   => Icons.Material.Filled.Warning
        };
}
