@using STRIKE
@using STRIKE.Inference
@using STRIKE.Services
@inject RegionAutofillService Autofill

<div class="predictor-card">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Color="Color.Success" />
                <MudText Typo="Typo.caption" Style="color:rgba(232,234,240,.6);">Autofill defaults for your region</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.GpsFixed"
                           Disabled="@_autofilling" OnClick="AutofillFromRegion">
                    @(_autofilling ? "Locating…" : "Autofill")
                </MudButton>
            </MudStack>
            @if (_autofillError != null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_autofillError</MudAlert>
            }

            <div class="param-block">
                <div class="param-label">Rainfall Intensity
                    <MudTooltip Text="Rate of rainfall in the area. Flash floods typically require sustained rates above 25 mm/hr." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – @RainfallMax.ToString("0") @(_rainfallUnit == "mm" ? "mm/hr" : "in/hr")</div>
                <MudSlider T="float" Min="0f" Max="@RainfallMax" Step="0.5f" @bind-Value="_rainfall"
                           Variant="Variant.Filled" Color="Color.Success" ValueLabel="true" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_rainfall.ToString("0.0")</MudChip>
                    <MudSelect T="string" Dense="true" @bind-Value="_rainfallUnit" Style="width:80px;">
                        <MudSelectItem Value="@("mm")">mm/hr</MudSelectItem>
                        <MudSelectItem Value="@("in")">in/hr</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Terrain Gradient
                    <MudTooltip Text="Slope of the terrain in degrees. Steeper slopes accelerate runoff speed and reduce absorption time." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 45 °</div>
                <MudSlider T="float" Min="0f" Max="45f" Step="1f" @bind-Value="_slope"
                           Variant="Variant.Filled" Color="Color.Success" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_slope.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">°</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Drainage Density
                    <MudTooltip Text="Total stream/channel length per unit area. Higher density means water is channelled faster and flooding can intensify quickly." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 5 km/km² (L/A)</div>
                <MudSlider T="float" Min="0f" Max="5f" Step="0.01f" @bind-Value="_dd"
                           Variant="Variant.Filled" Color="Color.Success" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_dd.ToString("0.00")</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">L/A</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Soil Saturation
                    <MudTooltip Text="Volumetric water content (VWC) of the soil. Saturated soil cannot absorb more water, turning rainfall directly into runoff." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 1 VWC</div>
                <MudSlider T="float" Min="0f" Max="1f" Step="0.01f" @bind-Value="_ui"
                           Variant="Variant.Filled" Color="Color.Success" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_ui.ToString("0.00")</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">VWC</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Convergence Index
                    <MudTooltip Text="Topographical tendency to channel runoff into a single point. Higher values mean water funnels faster into vulnerable low spots." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 1 CI</div>
                <MudSlider T="float" Min="0f" Max="1f" Step="0.01f" @bind-Value="_ci"
                           Variant="Variant.Filled" Color="Color.Success" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_ci.ToString("0.00")</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">CI</MudText>
                </MudStack>
            </div>

            <hr class="section-sep" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                <MudTooltip Text="Uses the FlashFloodTrustNet ensemble for higher-confidence results." Arrow="true">
                    <MudCheckBox @bind-Value="_useTrust" T="bool" Label="FlashFloodTrustNet" Color="Color.Primary" />
                </MudTooltip>
                <MudTooltip Text="Fetches supplementary online data during inference. Disabled on Apple platforms." Arrow="true">
                    <MudCheckBox @bind-Value="_useInternet" T="bool" Label="Use Internet"
                                 Disabled="@_isApplePlatform" Color="Color.Secondary" />
                </MudTooltip>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                       Size="Size.Large" StartIcon="@Icons.Material.Filled.Analytics"
                       Disabled="@_isPredicting" OnClick="RunPrediction">
                @(_isPredicting ? "Analysing…" : "Run Prediction")
            </MudButton>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudText Typo="Typo.overline" Style="opacity:.5;letter-spacing:.1em;">Flash Flood Risk Verdict</MudText>
            <div class="result-card mt-1 mb-4">
                @if (_isPredicting)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Success" Size="Size.Small" Class="mr-3" />
                    <MudText Class="result-text" Style="opacity:.6;">Running model…</MudText>
                }
                else if (!string.IsNullOrWhiteSpace(_predictionResult))
                {
                    <MudText Class="result-text">@_predictionResult</MudText>
                }
                else
                {
                    <MudText Style="opacity:.3;font-size:.85rem;">Adjust the parameters and press Run Prediction.</MudText>
                }
            </div>
            @if (_showAlert)
            {
                <MudAlert Severity="@_alertSeverity" Dense="true" Class="mb-3">@_alertMessage</MudAlert>
            }
            <MudExpansionPanels Elevation="0">
                <MudExpansionPanel Style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="opacity:.6;" />
                            <MudText Typo="Typo.body2">Parameter Reference</MudText>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Rainfall Intensity</strong> — Rainfall rate in mm/hr or in/hr.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Terrain Gradient (°)</strong> — Slope of the terrain.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Drainage Density (L/A)</strong> — Total stream length per unit area.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Soil Saturation (VWC)</strong> — Volumetric water content of the soil.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block"><strong>Convergence Index (CI)</strong> — Topographic tendency to channel runoff.</MudText>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
</div>

@code {
    private bool _isPredicting, _autofilling;
    private string? _autofillError;
    private string _alertMessage = ""; private Severity _alertSeverity = Severity.Normal; private bool _showAlert;
    private bool _useInternet = true;
    private bool _isApplePlatform = OperatingSystem.IsIOS() || OperatingSystem.IsMacOS();
    private float _rainfall = 20f, _slope = 5f, _ui = 0.6f, _dd = 2.5f, _ci = 0.5f;
    private string _rainfallUnit = "mm";
    private bool _useTrust = true;
    private string _predictionResult = "";
    private float RainfallMax => _rainfallUnit == "mm" ? 150f : 15f;

    protected override void OnInitialized() { if (_isApplePlatform) _useInternet = true; }

    private async Task AutofillFromRegion()
    {
        _autofilling = true; _autofillError = null; StateHasChanged();
        try
        {
            var d = await Autofill.GetFloodDefaultsAsync();
            if (d == null) { _autofillError = "Location unavailable. Please allow location access and try again."; return; }
            _rainfall = d.RainfallMmHr; _rainfallUnit = "mm";
        }
        catch (Exception ex) { _autofillError = $"Autofill failed: {ex.Message}"; }
        finally { _autofilling = false; StateHasChanged(); }
    }

    private async Task RunPrediction()
    {
        _isPredicting = true; _showAlert = false; _predictionResult = ""; StateHasChanged();
        try
        {
            var rain = _rainfallUnit == "mm" ? _rainfall : _rainfall * 25.4f;
            _predictionResult = await Task.Run(() => FlashFloodModelRunner.Predict(
                new[] { rain, _slope, _dd, _ui, _ci }, _useTrust, _useInternet));
            _alertMessage = "Prediction successful."; _alertSeverity = Severity.Success; _showAlert = true;
        }
        catch (Exception ex) { _predictionResult = ""; _alertMessage = $"Prediction failed: {ex.Message}"; _alertSeverity = Severity.Error; _showAlert = true; }
        finally { _isPredicting = false; StateHasChanged(); }
    }
}
