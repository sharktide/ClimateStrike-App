@* ══════════════════════════════════════════════════════
   FluvialFloodPredictor.razor  —  River-overflow floods
   ══════════════════════════════════════════════════════ *@
@using STRIKE
@using STRIKE.Inference
@using STRIKE.Services
@inject RegionAutofillService Autofill

<div class="predictor-card">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Color="Color.Tertiary" />
                <MudText Typo="Typo.caption" Style="color:rgba(232,234,240,.6);">Autofill defaults for your region</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Tertiary"
                           StartIcon="@Icons.Material.Filled.GpsFixed"
                           Disabled="@_autofilling" OnClick="AutofillFromRegion">
                    @(_autofilling ? "Locating…" : "Autofill")
                </MudButton>
            </MudStack>
            @if (_autofillError != null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_autofillError</MudAlert>
            }

            <div class="param-block">
                <div class="param-label">Rainfall
                    <MudTooltip Text="Sustained rainfall rate feeding into the river catchment. River flooding is typically driven by persistent rain over 12–72 hours." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – @RainfallMax.ToString("0") @(_rainfallUnit == "mm" ? "mm/hr" : "in/hr")</div>
                <MudSlider T="float" Min="0f" Max="@RainfallMax" Step="0.5f" @bind-Value="_rainfall"
                           Variant="Variant.Filled" Color="Color.Tertiary" ValueLabel="true" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_rainfall.ToString("0.0")</MudChip>
                    <MudSelect T="string" Dense="true" @bind-Value="_rainfallUnit" Style="width:80px;">
                        <MudSelectItem Value="@("mm")">mm/hr</MudSelectItem>
                        <MudSelectItem Value="@("in")">in/hr</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Relative Water Level
                    <MudTooltip Text="Water level relative to the normal river surface (3000 mm = bank-full). Values approaching the maximum indicate imminent overflow." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 6000 mm (bank-full ≈ 3000 mm)</div>
                <MudSlider T="float" Min="0f" Max="6000f" Step="1f" @bind-Value="_rwl"
                           Variant="Variant.Filled" Color="Color.Tertiary" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_rwl.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">mm</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Relative Slope
                    <MudTooltip Text="Terrain slope relative to the river channel. Flatter terrain retains floodwater longer; steeper terrain drains faster." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 90 °</div>
                <MudSlider T="float" Min="0f" Max="90f" Step="1f" @bind-Value="_slope"
                           Variant="Variant.Filled" Color="Color.Tertiary" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_slope.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">°</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Relative Elevation
                    <MudTooltip Text="Height of the location above the river water level. Areas below 5 m are highly vulnerable to fluvial inundation." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – @ElevationMax.ToString("0") @_elevationUnit</div>
                <MudSlider T="float" Min="@ElevationMin" Max="@ElevationMax" Step="10f" @bind-Value="_elevation"
                           Variant="Variant.Filled" Color="Color.Tertiary" ValueLabel="true" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_elevation.ToString()</MudChip>
                    <MudSelect T="string" Dense="true" @bind-Value="_elevationUnit" Style="width:72px;">
                        <MudSelectItem Value="@("m")">m</MudSelectItem>
                        <MudSelectItem Value="@("ft")">ft</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Distance From River
                    <MudTooltip Text="Straight-line distance from the nearest river channel. Proximity is the single strongest predictor of fluvial flood inundation." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – @distMax.ToString("0") @_distUnit</div>
                <MudSlider T="float" Min="0f" Max="@distMax" Step="1f" @bind-Value="_dist"
                           Variant="Variant.Filled" Color="Color.Tertiary" ValueLabel="true" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_dist.ToString()</MudChip>
                    <MudSelect T="string" Dense="true" @bind-Value="_distUnit" Style="width:72px;">
                        <MudSelectItem Value="@("m")">m</MudSelectItem>
                        <MudSelectItem Value="@("ft")">ft</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </div>

            <hr class="section-sep" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                <MudTooltip Text="Uses the FV-FloodTrustNet ensemble for higher-confidence results." Arrow="true">
                    <MudCheckBox @bind-Value="_useTrust" T="bool" Label="FV-FloodTrustNet" Color="Color.Primary" />
                </MudTooltip>
                <MudTooltip Text="Fetches supplementary online data during inference. Disabled on Apple platforms." Arrow="true">
                    <MudCheckBox @bind-Value="_useInternet" T="bool" Label="Use Internet"
                                 Disabled="@_isApplePlatform" Color="Color.Secondary" />
                </MudTooltip>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" FullWidth="true"
                       Size="Size.Large" StartIcon="@Icons.Material.Filled.Analytics"
                       Disabled="@_isPredicting" OnClick="RunPrediction">
                @(_isPredicting ? "Analysing…" : "Run Prediction")
            </MudButton>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudText Typo="Typo.overline" Style="opacity:.5;letter-spacing:.1em;">Fluvial Flood Risk Verdict</MudText>
            <div class="result-card mt-1 mb-4">
                @if (_isPredicting)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Tertiary" Size="Size.Small" Class="mr-3" />
                    <MudText Class="result-text" Style="opacity:.6;">Running model…</MudText>
                }
                else if (!string.IsNullOrWhiteSpace(_predictionResult))
                {
                    <MudText Class="result-text">@_predictionResult</MudText>
                }
                else
                {
                    <MudText Style="opacity:.3;font-size:.85rem;">Adjust the parameters and press Run Prediction.</MudText>
                }
            </div>
            @if (_showAlert)
            {
                <MudAlert Severity="@_alertSeverity" Dense="true" Class="mb-3">@_alertMessage</MudAlert>
            }
            <MudExpansionPanels Elevation="0">
                <MudExpansionPanel Style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="opacity:.6;" />
                            <MudText Typo="Typo.body2">Parameter Reference</MudText>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Rainfall</strong> — Rainfall rate feeding river catchment in mm/hr or in/hr.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Relative Water Level (mm)</strong> — Water level relative to normal river surface; bank-full ≈ 3000 mm.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Relative Slope (°)</strong> — Terrain slope relative to the river channel.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Relative Elevation</strong> — Height above river water level in metres or feet.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block"><strong>Distance From River</strong> — Distance from the nearest river channel.</MudText>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
</div>

@code {
    private bool _isPredicting, _autofilling;
    private string? _autofillError;
    private string _alertMessage = ""; private Severity _alertSeverity = Severity.Normal; private bool _showAlert;
    private bool _useInternet = true;
    private bool _isApplePlatform = OperatingSystem.IsIOS() || OperatingSystem.IsMacOS();
    private float _rainfall = 40f, _rwl = 3000f, _elevation = 5f, _slope = 5f, _dist = 25f;
    private string _rainfallUnit = "mm", _elevationUnit = "m", _distUnit = "m";
    private bool _useTrust = true;
    private string _predictionResult = "";
    private float RainfallMax => _rainfallUnit == "mm" ? 200f : 20f;
    private float distMax => _distUnit == "m" ? 2000f : 6000f;
    private float ElevationMin => 0f;
    private float ElevationMax => _elevationUnit == "ft" ? 10000f : 3000f;

    protected override void OnInitialized() { if (_isApplePlatform) _useInternet = true; }

    private async Task AutofillFromRegion()
    {
        _autofilling = true; _autofillError = null; StateHasChanged();
        try
        {
            var d = await Autofill.GetFloodDefaultsAsync();
            if (d == null) { _autofillError = "Location unavailable. Please allow location access and try again."; return; }
            _rainfall = d.RainfallMmHr; _rainfallUnit = "mm";
            var elv = d.Elevation; _elevation = elv > 0 ? Math.Min(elv, 3000f) : 5f; _elevationUnit = "m";
        }
        catch (Exception ex) { _autofillError = $"Autofill failed: {ex.Message}"; }
        finally { _autofilling = false; StateHasChanged(); }
    }

    private async Task RunPrediction()
    {
        _isPredicting = true; _showAlert = false; _predictionResult = ""; StateHasChanged();
        try
        {
            var rain = _rainfallUnit == "mm" ? _rainfall : _rainfall * 25.4f;
            var elM  = _elevationUnit == "ft" ? _elevation * 0.3048f : _elevation;
            var dstM = _distUnit == "ft" ? _dist * 0.3048f : _dist;
            _predictionResult = await Task.Run(() => FVFloodModelRunner.Predict(
                new[] { rain, _rwl, elM, _slope, dstM }, _useTrust, _useInternet));
            _alertMessage = "Prediction successful."; _alertSeverity = Severity.Success; _showAlert = true;
        }
        catch (Exception ex) { _predictionResult = ""; _alertMessage = $"Prediction failed: {ex.Message}"; _alertSeverity = Severity.Error; _showAlert = true; }
        finally { _isPredicting = false; StateHasChanged(); }
    }
}
