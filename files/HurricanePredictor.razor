@using STRIKE
@using STRIKE.Inference
@using STRIKE.Services
@inject RegionAutofillService Autofill

<div class="predictor-card">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Color="Color.Info" />
                <MudText Typo="Typo.caption" Style="color:rgba(232,234,240,.6);">Autofill defaults for your region</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.GpsFixed"
                           Disabled="@_autofilling" OnClick="AutofillFromRegion">
                    @(_autofilling ? "Locating…" : "Autofill")
                </MudButton>
            </MudStack>
            @if (_autofillError != null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_autofillError</MudAlert>
            }

            <div class="param-block">
                <div class="param-label">Sea Surface Temperature
                    <MudTooltip Text="Temperature of the ocean surface. Values above 26 °C (79 °F) are the primary fuel for hurricane intensification." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: @(SSTMin.ToString("0")) – @(SSTMax.ToString("0")) @(_sstUnit == "F" ? "°F" : "°C")</div>
                <MudSlider T="float" Min="@SSTMin" Max="@SSTMax" Step="0.1f" @bind-Value="_sst"
                           Variant="Variant.Filled" Color="Color.Info" ValueLabel="true" />
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_sst.ToString("0.0")</MudChip>
                    <MudSelect T="string" Dense="true" @bind-Value="_sstUnit" Style="width:72px;">
                        <MudSelectItem Value="@("C")">°C</MudSelectItem>
                        <MudSelectItem Value="@("F")">°F</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Ocean Heat Content
                    <MudTooltip Text="Total energy stored in the upper ocean layers. Higher values sustain and intensify storms even as they churn up cooler water." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 20 – 150 kJ/cm²</div>
                <MudSlider T="float" Min="20f" Max="150f" Step="1f" @bind-Value="_ohc"
                           Variant="Variant.Filled" Color="Color.Info" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_ohc.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">kJ/cm²</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Mid-Level Humidity
                    <MudTooltip Text="Moisture content in the mid-atmosphere (~5 km). Dry air intrusion at this level suppresses hurricane development." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 20 – 100 %</div>
                <MudSlider T="float" Min="20f" Max="100f" Step="1f" @bind-Value="_humidity"
                           Variant="Variant.Filled" Color="Color.Info" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_humidity.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">%</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Vertical Wind Shear
                    <MudTooltip Text="Difference in wind speed between upper and lower atmosphere. High shear (> 15 m/s) tears storms apart; low shear favours intensification." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0 – 30 m/s</div>
                <MudSlider T="float" Min="0f" Max="30f" Step="1f" @bind-Value="_shear"
                           Variant="Variant.Filled" Color="Color.Info" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_shear.ToString()</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">m/s</MudText>
                </MudStack>
            </div>

            <div class="param-block">
                <div class="param-label">Potential Vorticity
                    <MudTooltip Text="A conserved atmospheric quantity that combines rotation and stratification. High values indicate favourable conditions for organised cyclonic structure." Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size:15px;opacity:.5;" />
                    </MudTooltip>
                </div>
                <div class="param-hint">Range: 0.0 – 3.0 PVU</div>
                <MudSlider T="float" Min="0.0f" Max="3.0f" Step="0.01f" @bind-Value="_vorticity"
                           Variant="Variant.Filled" Color="Color.Info" ValueLabel="true" />
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark">@_vorticity.ToString("0.00")</MudChip>
                    <MudText Typo="Typo.caption" Style="opacity:.6;">PVU</MudText>
                </MudStack>
            </div>

            <hr class="section-sep" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                <MudTooltip Text="Uses the HurricaneTrustNet ensemble for higher-confidence results." Arrow="true">
                    <MudCheckBox @bind-Value="_useTrust" T="bool" Label="HurricaneTrustNet" Color="Color.Primary" />
                </MudTooltip>
                <MudTooltip Text="Fetches supplementary online data during inference. Disabled on Apple platforms." Arrow="true">
                    <MudCheckBox @bind-Value="_useInternet" T="bool" Label="Use Internet"
                                 Disabled="@_isApplePlatform" Color="Color.Secondary" />
                </MudTooltip>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true"
                       Size="Size.Large" StartIcon="@Icons.Material.Filled.Analytics"
                       Disabled="@_isPredicting" OnClick="RunPrediction">
                @(_isPredicting ? "Analysing…" : "Run Prediction")
            </MudButton>
        </MudItem>

        <MudItem xs="12" sm="6">
            <MudText Typo="Typo.overline" Style="opacity:.5;letter-spacing:.1em;">Hurricane Formation Verdict</MudText>
            <div class="result-card mt-1 mb-4">
                @if (_isPredicting)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Info" Size="Size.Small" Class="mr-3" />
                    <MudText Class="result-text" Style="opacity:.6;">Running model…</MudText>
                }
                else if (!string.IsNullOrWhiteSpace(_predictionResult))
                {
                    <MudText Class="result-text">@_predictionResult</MudText>
                }
                else
                {
                    <MudText Style="opacity:.3;font-size:.85rem;">Adjust the parameters and press Run Prediction.</MudText>
                }
            </div>
            @if (_showAlert)
            {
                <MudAlert Severity="@_alertSeverity" Dense="true" Class="mb-3">@_alertMessage</MudAlert>
            }
            <MudExpansionPanels Elevation="0">
                <MudExpansionPanel Style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="opacity:.6;" />
                            <MudText Typo="Typo.body2">Parameter Reference</MudText>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Sea Surface Temperature (°C/°F)</strong> — Temperature of the ocean surface.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Ocean Heat Content (kJ/cm²)</strong> — Energy stored in the upper ocean layers.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Mid-Level Humidity (%)</strong> — Moisture content in the middle atmosphere.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2"><strong>Vertical Wind Shear (m/s)</strong> — Difference in wind speed at different altitudes.</MudText>
                        <MudText Typo="Typo.caption" Class="d-block"><strong>Potential Vorticity (PVU)</strong> — Measure of atmospheric rotation potential.</MudText>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
</div>

@code {
    private bool _isPredicting, _autofilling;
    private string? _autofillError;
    private string _alertMessage = ""; private Severity _alertSeverity = Severity.Normal; private bool _showAlert;
    private bool _useInternet = true;
    private bool _isApplePlatform = OperatingSystem.IsIOS() || OperatingSystem.IsMacOS();
    private float _sst = 29.0f; private string _sstUnit = "C";
    private float _ohc = 95f, _humidity = 65f, _shear = 9f, _vorticity = 1.2f;
    private bool _useTrust = true;
    private string _predictionResult = "";
    private float SSTMin => _sstUnit == "F" ? 40f : 24f;
    private float SSTMax => _sstUnit == "F" ? 140f : 32f;

    protected override void OnInitialized() { if (_isApplePlatform) _useInternet = true; }

    private async Task AutofillFromRegion()
    {
        _autofilling = true; _autofillError = null; StateHasChanged();
        try
        {
            var d = await Autofill.GetHurricaneDefaultsAsync();
            if (d == null) { _autofillError = "Location unavailable. Please allow location access and try again."; return; }
            _sst = d.SST; _ohc = d.OHC; _humidity = d.Humidity; _shear = d.Shear; _vorticity = d.Vorticity;
        }
        catch (Exception ex) { _autofillError = $"Autofill failed: {ex.Message}"; }
        finally { _autofilling = false; StateHasChanged(); }
    }

    private async Task RunPrediction()
    {
        _isPredicting = true; _showAlert = false; _predictionResult = ""; StateHasChanged();
        try
        {
            var sstC = _sstUnit == "F" ? (_sst - 32f) * 5f / 9f : _sst;
            _predictionResult = await Task.Run(() => HurricaneModelRunner.Predict(
                new[] { sstC, _ohc, _humidity, _shear, _vorticity }, _useTrust, _useInternet));
            _alertMessage = "Prediction successful."; _alertSeverity = Severity.Success; _showAlert = true;
        }
        catch (Exception ex) { _predictionResult = ""; _alertMessage = $"Prediction failed: {ex.Message}"; _alertSeverity = Severity.Error; _showAlert = true; }
        finally { _isPredicting = false; StateHasChanged(); }
    }
}
